# URL publique du site (utilisée dans les liens de confirmation e-mail Supabase)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (voir Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé de service : ne JAMAIS exposer côté client, utilisée uniquement dans les
# route handlers serveur (webhook de paiement CinetPay)
SUPABASE_SERVICE_ROLE_KEY=

# Secret partagé pour authentifier les appels de Vercel Cron (statistiques
# quotidiennes) — générer une valeur aléatoire et la renseigner aussi dans
# Vercel > Settings > Environment Variables
CRON_SECRET=

# CinetPay (agrège Wave, Orange Money, MTN MoMo, Moov) — achat de packs de crédits
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# IA (module isolé, désactivable depuis /admin/parametres sans impact sur le
# reste de l'app) — aide à la rédaction des demandes
ANTHROPIC_API_KEY=

# Cloudflare R2 (stockage média — jamais dans Supabase). R2_PUBLIC_URL est
# l'URL publique du bucket (domaine r2.dev ou domaine personnalisé connecté).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
